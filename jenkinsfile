pipeline {
    agent any

    environment {
        IMAGE_NAME = "cicd-app"
    }

    stages {

        stage('Clone Code') {
            steps {
                echo "Cloning repository..."
            }
        }

        stage('Build') {
            steps {
                sh 'npm install || true'
            }
        }

        stage('Test') {
            steps {
                sh 'chmod +x test.sh'
                sh './test.sh'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME .'
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker stop cicd-container || true
                docker rm cicd-container || true
                docker run -d -p 3000:3000 --name cicd-container $IMAGE_NAME
                '''
            }
        }
    }
}